{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio",
  "main": "./src/worker.ts",  
  "compatibility_date": "2026-04-08",
  "compatibility_flags": ["nodejs_compat"],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "portfolio-db"    }
  ],
  "r2_buckets": [
    {
      "binding": "portfolio-bucket",
      "bucket_name": "portfolio-bucket"
    }
  ]
}