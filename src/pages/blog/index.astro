---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import PageHeader from "../../components/PageHeader.astro";
import PostRow from "../../components/PostRow.astro";

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
    status: "published",
	orderBy: { published_at: "desc" },
});
if (Astro.cache?.enabled) Astro.cache.set(cacheHint);
---

<Base
	title="Blog"
	description="Notes on web development, electronics, and machine learning."
>
	<PageHeader
		kicker="Blog"
		title="Writing."
		lede="Long notes here, you can find short notes on twitter."
	/>

	{
		posts.length > 0 ? (
			<ul class="border-b border-rule">
				{posts.map((post) => <PostRow post={post} />)}
			</ul>
		) : (
			<p class="text-lg text-muted">
				No posts yet — the first one is being written.
			</p>
		)
	}
</Base>
