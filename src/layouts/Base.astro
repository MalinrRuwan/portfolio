---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import { Font } from "astro:assets";
import SiteLogo from "../components/SiteLogo.astro";
import { profile } from "../data/profile";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: "website" | "article";
}

const { title, description, image, type = "website" } = Astro.props;
const settings = await getSiteSettings();
const siteTitle = settings?.title || "Malin Dhamsara";
const fullTitle = title ? `${title} — ${siteTitle}` : siteTitle;
const siteDescription = settings?.tagline || "";

const menu = await getMenu("primary");
const pathname = Astro.url.pathname;

const isCurrent = (url: string) =>
	url !== "/" && (pathname === url || pathname.startsWith(`${url}/`));

const pageCtx = createPublicPageContext({
	Astro,
	kind: "custom",
	pageType: type,
	title: fullTitle,
	pageTitle: title ?? siteTitle,
	description: description || siteDescription,
	canonical: Astro.url.href,
	image,
	seo: { ogImage: image },
	siteName: siteTitle,
});

const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en" class="no-js">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{fullTitle}</title>
		<EmDashHead page={pageCtx} />
		<Font cssVariable="--font-inter" preload />
		<Font cssVariable="--font-crimson" preload />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={`${siteTitle} RSS Feed`}
			href="/rss.xml"
		/>
		<link rel="icon" href="/favicon.ico" sizes="48x48" type="image/x-icon" />
				<link rel="icon" href="/favicon.svg" sizes="any" type="image/svg+xml" />
		<script is:inline>
			document.documentElement.classList.remove("no-js");
		</script>
	</head>
	<body class="flex min-h-screen flex-col">
		<a
			href="#main"
			class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:rounded focus:bg-ink focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-bg focus:shadow-sm"
		>
			Skip to main content
		</a>

		<header
			class="site-header sticky top-0 z-50 transition-[background-color,border-color,backdrop-filter] duration-300"
			data-header
		>
			<nav
				class="mx-auto flex w-full max-w-site items-center justify-between gap-6 px-6 py-5 sm:px-10"
				aria-label="Primary navigation"
			>
				<a
					href="/"
					class="relative z-[55] transition-opacity hover:opacity-70"
					aria-label={siteTitle}
				>
					<SiteLogo class="site-logo h-8 w-auto" />
				</a>

				{/* Desktop links */}
				<div class="hidden items-baseline gap-8 sm:flex">
					{
						menu?.items.map((item) => (
							<a
								href={item.url}
								target={item.target}
								aria-current={isCurrent(item.url) ? "page" : undefined}
								class:list={[
									"u-link text-sm font-medium",
									isCurrent(item.url)
										? "text-ink decoration-ink"
										: "text-muted hover:text-ink",
								]}
							>
								{item.label}
							</a>
						))
						}
				</div>

				{/* Mobile menu toggle */}
				<button
					type="button"
					class="menu-toggle relative z-[55] flex h-11 w-11 flex-col items-center justify-center gap-1.5 rounded sm:hidden"
					aria-expanded="false"
					aria-controls="site-menu"
					aria-label="Toggle navigation menu"
				>
					<span class="menu-line" aria-hidden="true"></span>
					<span class="menu-line" aria-hidden="true"></span>
				</button>

				{/* Mobile menu panel */}
				<div
					id="site-menu"
					class="site-menu fixed inset-x-0 top-0 z-40 min-h-screen opacity-0 transition-[opacity,transform] duration-300 ease-out sm:hidden"
					role="dialog"
					aria-modal="true"
					aria-label="Primary navigation"
					aria-hidden="true"
					inert
				>
					<div class="site-menu-inner flex min-h-screen flex-col border-b border-rule bg-bg px-6 pb-12 pt-28 shadow-sm">
						<div class="mx-auto flex max-w-site flex-col gap-2">
							{
								menu?.items.map((item, i) => (
									<a
										href={item.url}
										target={item.target}
										aria-current={isCurrent(item.url) ? "page" : undefined}
										class:list={[
											"site-menu-link block py-3 text-3xl font-semibold tracking-tight transition-colors",
											isCurrent(item.url)
												? "text-ink"
												: "text-muted hover:text-ink",
										]}
										style={`--menu-delay: ${i * 40}ms`}
									>
										{item.label}
									</a>
								))
							}
						</div>
					</div>
				</div>
			</nav>
		</header>

		<main id="main" class="mx-auto w-full max-w-site grow px-6 sm:px-10">
			<slot />
		</main>

		<footer
			class="footer-canvas-wrap relative overflow-hidden mx-auto w-full max-w-site px-6 sm:px-10"
		>
			<canvas
				id="footer-canvas"
				class="pointer-events-none absolute inset-0 -z-10 opacity-0 transition-opacity duration-500"
				aria-hidden="true"
			></canvas>
			<div
				class="relative z-10 mt-28 flex flex-col gap-3 border-t border-rule py-8 text-sm text-muted sm:flex-row sm:items-center sm:justify-between"
			>
				<p>&copy; {year} {siteTitle}</p>
				<div class="flex items-center gap-5">
					{
						profile.socials.map((social) => (
							<a
								href={social.url}
								class="u-link"
								{...(social.url.startsWith("http")
									? { target: "_blank", rel: "noopener noreferrer" }
									: {})}
							>
								{social.label}
							</a>
						))
					}
				</div>
			</div>
		</footer>

		<script>
			// Scroll-aware header background
			const header = document.querySelector<HTMLElement>("[data-header]");
			if (header) {
				let ticking = false;
				const onScroll = () => {
					if (!ticking) {
						requestAnimationFrame(() => {
							header.classList.toggle("is-scrolled", window.scrollY > 8);
							ticking = false;
						});
						ticking = true;
					}
				};
				window.addEventListener("scroll", onScroll, { passive: true });
				header.classList.toggle("is-scrolled", window.scrollY > 8);
			}

			// Mobile menu
			const toggle = document.querySelector<HTMLButtonElement>(".menu-toggle");
			const menu = document.getElementById("site-menu");
			if (toggle && menu) {
				const focusableSelector =
					'a[href], button, input, textarea, select, details, [tabindex]:not([tabindex="-1"])';
				const getFocusable = () =>
					Array.from(menu.querySelectorAll<HTMLElement>(focusableSelector)).filter(
						(el) => !el.hasAttribute("disabled") && !el.getAttribute("aria-hidden"),
					);

				const menuLinks = menu.querySelectorAll<HTMLAnchorElement>("a");
				menuLinks.forEach((link) => (link.tabIndex = -1));
				let isOpen = false;

				const setOpen = (open: boolean) => {
					const wasOpen = isOpen;
					isOpen = open;
					toggle.setAttribute("aria-expanded", String(open));
					menu.classList.toggle("is-open", open);
					menu.setAttribute("aria-hidden", String(!open));
					menuLinks.forEach((link) => (link.tabIndex = open ? 0 : -1));
					if (open) {
						menu.removeAttribute("inert");
						document.body.classList.add("menu-open-body");
						const first = getFocusable()[0];
						if (first) first.focus();
					} else {
						menu.setAttribute("inert", "");
						document.body.classList.remove("menu-open-body");
						if (wasOpen) toggle.focus();
					}
				};

				toggle.addEventListener("click", () => {
					setOpen(toggle.getAttribute("aria-expanded") !== "true");
				});

				// Close on Escape
				document.addEventListener("keydown", (e) => {
					if (e.key === "Escape" && toggle.getAttribute("aria-expanded") === "true") {
						setOpen(false);
					}
				});

				// Close on clicking outside the panel
				document.addEventListener("click", (e) => {
					if (
						toggle.getAttribute("aria-expanded") === "true" &&
						e.target instanceof Node &&
						!toggle.contains(e.target) &&
						!menu.contains(e.target)
					) {
						setOpen(false);
					}
				});

				// Close on navigating (link click)
				menu.querySelectorAll("a").forEach((link) => {
					link.addEventListener("click", () => setOpen(false));
				});

				// Focus trap
				menu.addEventListener("keydown", (e) => {
					if (e.key !== "Tab") return;
					const focusable = getFocusable();
					if (focusable.length === 0) return;
					const first = focusable[0];
					const last = focusable[focusable.length - 1];
					if (e.shiftKey && document.activeElement === first) {
						e.preventDefault();
						last.focus();
					} else if (!e.shiftKey && document.activeElement === last) {
						e.preventDefault();
						first.focus();
					}
				});

				// Close when crossing into desktop breakpoint
				window.addEventListener("resize", () => {
					if (window.innerWidth >= 640 && toggle.getAttribute("aria-expanded") === "true") {
						setOpen(false);
					}
				});
			}

			// Scroll reveal
			const els = document.querySelectorAll<HTMLElement>(".reveal");
			const reduced = window.matchMedia(
				"(prefers-reduced-motion: reduce)",
			).matches;
			if (reduced || !("IntersectionObserver" in window)) {
				els.forEach((el) => el.classList.add("is-revealed"));
			} else {
				const io = new IntersectionObserver(
					(entries) => {
						for (const entry of entries) {
							if (entry.isIntersecting) {
								entry.target.classList.add("is-revealed");
								io.unobserve(entry.target);
							}
						}
					},
					{ rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
				);
				els.forEach((el) => io.observe(el));
			}

			/* Footer glitter canvas — disabled for now
			const footerCanvas = document.getElementById("footer-canvas") as HTMLCanvasElement | null;
			const footerWrap = document.querySelector<HTMLElement>(".footer-canvas-wrap");
			if (footerCanvas && footerWrap && !reduced) {
				const ctx = footerCanvas.getContext("2d");
				if (ctx) {

				const palette = [
					"#ffffff",
					"#f4e4bc",
					"#e9c46a",
				].map((c) => {
					const s = c.trim();
					const num = parseInt(s.slice(1), 16);
					return [(num >> 16) & 255, (num >> 8) & 255, num & 255] as const;
				});

				const particleCount = 220;
				const focal = 0.12;
				const stepZ = 0.0032;
				const starScale = 2.1;
				const turb = 0.1;
				const glitter = 0.2;
				const brightness = 0.7;
				const trail = 0.85;

				type Star = {
					x: number;
					y: number;
					z: number;
					px: number;
					py: number;
					seed: number;
					vmul: number;
					colorIdx: number;
					flashUntil: number;
					nextFlash: number;
				};

				const stars: Star[] = [];
				const sizeRef = { w: 0, h: 0, dpr: 1 };
				let elapsed = 0;
				let lastT = performance.now();
				let raf: number | null = null;
				let active = false;

				const resetStar = (s: Star, initial = false) => {
					const angle = Math.random() * Math.PI * 2;
					const radius = (0.2 + Math.random() * 0.8) * (80 / 15);
					s.x = Math.cos(angle) * radius;
					s.y = Math.sin(angle) * radius;
					s.z = initial ? Math.random() : 1.0;
					s.px = NaN;
					s.py = NaN;
					s.seed = Math.random() * 1000;
					s.vmul = 0.6 + Math.random() * 0.8;
					s.colorIdx = Math.floor(Math.random() * 3);
					s.flashUntil = 0;
					s.nextFlash = elapsed + 1 + Math.random() * 4 * (1 / Math.max(0.0001, glitter));
				};

				while (stars.length < particleCount) {
					const s = { x: 0, y: 0, z: 0, px: NaN, py: NaN, seed: 0, vmul: 1, colorIdx: 0, flashUntil: 0, nextFlash: 0 };
					resetStar(s, true);
					stars.push(s);
				}

				const resize = (entry?: ResizeObserverEntry) => {
					const dpr = Math.min(window.devicePixelRatio || 1, 2);
					const cr = entry?.contentRect;
					const rectW = cr?.width || footerWrap.clientWidth || footerWrap.getBoundingClientRect().width;
					const rectH = cr?.height || footerWrap.clientHeight || footerWrap.getBoundingClientRect().height;
					const w = Math.max(1, Math.floor(rectW) || 600);
					const h = Math.max(1, Math.floor(rectH) || 400);
					if (sizeRef.w === w && sizeRef.h === h && sizeRef.dpr === dpr) return;
					sizeRef.w = w;
					sizeRef.h = h;
					sizeRef.dpr = dpr;
					footerCanvas.width = Math.floor(w * dpr);
					footerCanvas.height = Math.floor(h * dpr);
					footerCanvas.style.width = `${w}px`;
					footerCanvas.style.height = `${h}px`;
					ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
					ctx.clearRect(0, 0, w, h);
				};
				resize();

				const ro = new ResizeObserver((entries) => resize(entries[0]));
				ro.observe(footerWrap);

				const drawFrame = (deltaSec: number) => {
					const { w, h } = sizeRef;
					const cx = w / 2;
					const cy = h / 2;
					const projScale = Math.min(w, h) * 0.9;
					const dt = Math.max(0.001, Math.min(0.1, deltaSec)) * 60;

					const keep = Math.pow(Math.min(0.98, Math.max(0, trail)), dt);
					const trailAlpha = Math.max(0.02, 1 - keep);
					ctx.globalAlpha = 1;
					ctx.globalCompositeOperation = "destination-out";
					ctx.fillStyle = `rgba(0, 0, 0, ${trailAlpha})`;
					ctx.fillRect(0, 0, w, h);
					ctx.globalCompositeOperation = "lighter";

					const rgbStrs = palette.map((c) => `rgb(${c[0]}, ${c[1]}, ${c[2]})`);

					for (let i = 0; i < stars.length; i++) {
						const s = stars[i];
						const vz = stepZ * s.vmul * dt;
						s.z -= vz;
						if (s.z <= focal) {
							resetStar(s);
							continue;
						}

						let tx = s.x;
						let ty = s.y;
						if (turb > 0) {
							const t = elapsed * 1.2 + s.seed;
							const amp = turb * (1 - s.z) * 0.25;
							tx += Math.sin(t + s.seed) * amp;
							ty += Math.cos(t * 1.13 + s.seed * 0.7) * amp;
						}

						const persp = focal / Math.max(s.z, 0.0001);
						const sx = cx + tx * persp * projScale;
						const sy = cy + ty * persp * projScale;

						if (sx < -20 || sx > w + 20 || sy < -20 || sy > h + 20) {
							resetStar(s);
							continue;
						}

						let flashMult = 1;
						if (glitter > 0) {
							if (elapsed >= s.nextFlash && s.flashUntil < elapsed) {
								s.flashUntil = elapsed + 0.04 + Math.random() * 0.07;
								s.nextFlash = elapsed + 1 + Math.random() * 4 * (1 / Math.max(0.0001, glitter));
							}
							if (elapsed <= s.flashUntil) flashMult = 1 + 2.5 * glitter;
						}

						const sizePersp = Math.min(2.5, (focal / Math.max(s.z, 0.0001)) * 0.6);
						const baseR = Math.max(0.25, starScale * (0.4 + sizePersp));
						const maxR = 1 + starScale * 2.5;
						const r = Math.min(baseR * flashMult, maxR);
						const lifeT = 1 - s.z;
						const a = Math.min(1, lifeT * 0.9 + 0.05) * brightness * (flashMult > 1 ? 1 : 0.85);
						const colStr = rgbStrs[s.colorIdx];

						if (!Number.isNaN(s.px) && !Number.isNaN(s.py)) {
							ctx.globalAlpha = a * 0.5;
							ctx.strokeStyle = colStr;
							ctx.lineWidth = Math.max(0.4, r * 0.4);
							ctx.beginPath();
							ctx.moveTo(s.px, s.py);
							ctx.lineTo(sx, sy);
							ctx.stroke();
						}

						ctx.globalAlpha = a;
						ctx.fillStyle = colStr;
						ctx.fillRect(sx - r, sy - r, r * 2, r * 2);

						if (flashMult > 1) {
							const rf = Math.min(r * 1.4, maxR * 1.4);
							ctx.globalAlpha = a * 0.5;
							ctx.fillRect(sx - rf, sy - rf, rf * 2, rf * 2);
						}

						s.px = sx;
						s.py = sy;
					}

					ctx.globalAlpha = 1;
					ctx.globalCompositeOperation = "source-over";
					elapsed += Math.min(0.1, Math.max(0, deltaSec));
				};

				const loop = (t: number) => {
					const delta = (t - lastT) / 1000;
					lastT = t;
					drawFrame(delta);
					raf = requestAnimationFrame(loop);
				};

				const start = () => {
					if (active) return;
					active = true;
					ctx.clearRect(0, 0, sizeRef.w, sizeRef.h);
					footerCanvas.classList.remove("opacity-0");
					lastT = performance.now();
					raf = requestAnimationFrame(loop);
				};

				const stop = () => {
					active = false;
					footerCanvas.classList.add("opacity-0");
					if (raf != null) cancelAnimationFrame(raf);
					raf = null;
				};

				footerWrap.addEventListener("mouseenter", start);
				footerWrap.addEventListener("mouseleave", stop);
				}
			}
			*/
		</script>

		<style>
			.site-header.is-scrolled {
				background-color: var(--color-bg);
				border-bottom: 1px solid var(--color-rule);
			}

			.menu-line {
				display: block;
				width: 1.25rem;
				height: 1.5px;
				background-color: var(--color-ink);
				transition: transform 250ms ease, opacity 250ms ease;
				transform-origin: center;
			}
			.menu-toggle[aria-expanded="true"] .menu-line:first-child {
				transform: translateY(3.5px) rotate(45deg);
			}
			.menu-toggle[aria-expanded="true"] .menu-line:last-child {
				transform: translateY(-3.5px) rotate(-45deg);
			}

			.site-menu {
				--tw-translate-y: -1rem;
				transform: translateY(var(--tw-translate-y));
				pointer-events: none;
			}
			.site-menu.is-open {
				pointer-events: auto;
				opacity: 1;
				--tw-translate-y: 0;
			}
			.site-menu-link {
				opacity: 0;
				transform: translateY(0.5rem);
				transition:
					opacity 350ms var(--ease-out-expo) var(--menu-delay, 0ms),
					transform 350ms var(--ease-out-expo) var(--menu-delay, 0ms);
			}
			.site-menu.is-open .site-menu-link {
				opacity: 1;
				transform: translateY(0);
			}

			.menu-open-body {
				overflow: hidden;
				overscroll-behavior: none;
			}
		</style>
	</body>
</html>
