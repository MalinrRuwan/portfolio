---
interface Props {
	index: string;
	label: string;
}

const { index, label } = Astro.props;
---

<header class="reveal mb-10 flex items-baseline gap-4 sm:mb-14">
	<span class="kicker text-faint">{index}</span>
	<h2 class="kicker">{label}</h2>
	<div aria-hidden="true" class="ml-2 h-px grow bg-rule"></div>
</header>
