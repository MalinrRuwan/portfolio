---
interface Props {
	id: string;
	title: string;
	description?: string;
}

const { id, title, description } = Astro.props;
---

<dialog
	id={id}
	class="group m-auto w-[calc(100%-3rem)] sm:w-full sm:max-w-lg rounded-xl bg-transparent p-0 overflow-hidden backdrop:bg-black/60 backdrop:backdrop-blur-sm open:animate-in open:fade-in open:zoom-in-95"
>
	<div class="flex flex-col overflow-hidden rounded-xl bg-chip shadow-2xl max-h-[90dvh]">
		<!-- Header -->
		<div class="flex shrink-0 items-start justify-between gap-4 px-6 py-5">
			<div class="min-w-0">
				<h2 class="text-xl font-semibold tracking-tight">
					{title}
				</h2>
				{
					description && (
						<p class="mt-1.5 text-base/7 text-pretty">
							{description}
						</p>
					)
				}
			</div>

			<!-- Close Button (Native Dialog Form) -->
			<form method="dialog" class="shrink-0">
				<button
					class="flex h-8 w-8 items-center justify-center rounded-md text-faint transition-colors hover:bg-black/5 hover:text-inherit dark:hover:bg-white/10"
					aria-label="Close dialog"
				>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="18"
						height="18"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<line x1="18" y1="6" x2="6" y2="18" />
						<line x1="6" y1="6" x2="18" y2="18" />
					</svg>
				</button>
			</form>
		</div>

		<!-- Body content passed via default slot -->
		<div class="dialog-body flex-1 overflow-y-auto px-6 pb-6 text-base text-muted">
			<slot />
		</div>

		<!-- Optional Footer content passed via named slot -->
		{
			Astro.slots.has("footer") && (
				<div class="mt-auto flex items-center justify-end gap-3 bg-black/5 px-6 py-4 dark:bg-white/5">
					<slot name="footer" />
				</div>
			)
		}
	</div>
</dialog>

<style>
	.dialog-body {
		scrollbar-width: none; /* Firefox */
	}
	.dialog-body::-webkit-scrollbar {
		display: none; /* Chrome, Safari, Edge */
	}
</style>

<script>
	// Closes the dialog when clicking outside the content area (on the backdrop)
	const dialogs = document.querySelectorAll("dialog");

	dialogs.forEach((dialog) => {
		dialog.addEventListener("click", (e) => {
			const rect = dialog.getBoundingClientRect();
			const isInDialog =
				rect.top <= e.clientY &&
				e.clientY <= rect.top + rect.height &&
				rect.left <= e.clientX &&
				e.clientX <= rect.left + rect.width;

			if (!isInDialog) {
				dialog.close();
			}
		});
	});
</script>
