---
interface Props {
  class?: string;
}
const { class: className = "site-logo h-7 w-auto" } = Astro.props;
---
<svg
  class={className}
  viewBox="0 0 1516 723"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  shape-rendering="geometricPrecision"
  aria-hidden="true"
>
  <path
    class="logo-wing"
    d="M6.92729 718L419.036 4H717.927L305.819 718H6.92729Z"
    stroke-width="8"
  />
  <path
    class="logo-wing"
    d="M1171.04 716.496C1553.04 716.496 1693.04 4 1168.04 4L755.927 718L1171.04 716.496Z"
    stroke-width="8"
  />
  <path
    class="logo-core"
    d="M461.927 718H760.819L1172.93 4H874.035L461.927 718Z"
    stroke-width="8"
  />
</svg>

<style>
  .site-logo {
    display: block;
    transform: translateZ(0);
    backface-visibility: hidden;
  }
  .site-logo path {
    stroke-width: 8;
  }
  .site-logo .logo-wing {
    fill: light-dark(#fff, var(--color-bg));
    stroke: var(--color-ink);
  }
  .site-logo .logo-core {
    fill: light-dark(var(--color-ink), #fff);
    stroke: var(--color-ink);
  }
</style>
